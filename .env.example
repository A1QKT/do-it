# Copy to .env — never commit .env
# Get a key at https://openrouter.ai/keys

OPENROUTER_API_KEY=sk-or-v1-xxxxxxxx
# Vision-capable model (see https://openrouter.ai/models)
OPENROUTER_MODEL=openai/gpt-4o-mini

# Optional (OpenRouter leaderboard attribution)
OPENROUTER_HTTP_REFERER=https://localhost
OPENROUTER_APP_TITLE=traffic-simulation

# CORS for browser frontends (comma-separated, or * for dev)
CORS_ORIGINS=*
