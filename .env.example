# Copy to .env — never commit .env
# Get a key at https://openrouter.ai/keys

OPENROUTER_API_KEY=sk-or-v1-xxxxxxxx
# Vision-capable model (see https://openrouter.ai/models)
OPENROUTER_MODEL=openai/gpt-4o-mini
# Audio transcription: default is local Whisper (faster-whisper). Set to openrouter to use API instead.
# AUDIO_TRANSCRIBE_BACKEND=whisper
# AUDIO_TRANSCRIBE_BACKEND=openrouter

# Local Whisper (pip install -r api/requirements.txt — model downloads on first run)
WHISPER_MODEL_SIZE=base
WHISPER_DEVICE=cpu
# WHISPER_COMPUTE_TYPE=int8
WHISPER_LANGUAGE=vi

# OpenRouter transcription (only when AUDIO_TRANSCRIBE_BACKEND=openrouter); also fallback if Whisper missing
OPENROUTER_TRANSCRIBE_MODEL=google/gemini-2.0-flash-001
# Legacy one-shot audio JSON (?direct=true on /v1/media/audio-score)
OPENROUTER_MEDIA_AUDIO_MODEL=google/gemini-2.0-flash-001

# Optional (OpenRouter leaderboard attribution)
OPENROUTER_HTTP_REFERER=https://localhost
OPENROUTER_APP_TITLE=traffic-simulation

# CORS for browser frontends (comma-separated, or * for dev)
CORS_ORIGINS=*

# Optional: path to media seed JSON for GET /v1/media-seed/latest (default: ./media_seed_export.json from repo root)
# MEDIA_SEED_EXPORT_PATH=/absolute/or/relative/to/repo/root/export.json
# Label used for every image score in /v1/media-seed/latest `route` field (default: Ngã 4 Phú Nhuận)
# MEDIA_SEED_IMAGE_ROUTE_NAME=Ngã 4 Phú Nhuận

# Media seed crawl (Playwright Chromium) — on Linux Docker/VPS, if launch fails:
# PLAYWRIGHT_CHROMIUM_NO_SANDBOX=1
# PLAYWRIGHT_CHROMIUM_EXTRA_ARGS=--single-process
# CI=1 also enables no-sandbox in the crawler.
